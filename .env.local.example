# Ejemplo de variables de entorno para producción
# Copia este archivo a .env.local y completa los valores

# Base de datos (Producción)
DATABASE_URL="postgresql://user:password@localhost:5432/festival_cubanada"

# Pasarela de Pago
PAYMENT_GATEWAY="niubiz" # niubiz, culqi, mercadopago, stripe
PAYMENT_API_KEY="tu_api_key_aqui"
PAYMENT_SECRET_KEY="tu_secret_key_aqui"

# Email Service (Resend recomendado)
RESEND_API_KEY="re_xxxxxxxxxxxxx"
EMAIL_FROM="tickets@perionentertainment.com"

# NextAuth (Autenticación de admin)
NEXTAUTH_SECRET="genera_un_secret_aleatorio_aqui"
NEXTAUTH_URL="http://localhost:3000"

# URL de producción
NEXT_PUBLIC_APP_URL="https://festival-cubanada.com"

# Analytics (opcional)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Modo de desarrollo
NODE_ENV="development" # development o production
