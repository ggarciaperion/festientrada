# ── Izipay — Pasarela de pagos ───────────────────────────────
# Obtén tus claves en: panel.izipay.pe → Configuración → Claves API
# (Para sandbox: sandbox-panel.izipay.pe)

# Código de comercio (Izipay te lo asigna al registrarte)
IZIPAY_SHOP_ID=TU_CODIGO_DE_COMERCIO

# Clave de API / Password  (PRIVADA — nunca la expongas en el frontend)
IZIPAY_API_KEY=TU_CLAVE_API

# Clave HMAC-SHA256 (PRIVADA — para validar respuestas de pago)
IZIPAY_HASH_KEY=TU_CLAVE_HASH

# Clave pública (seguro exponerla — usada por el formulario JS)
NEXT_PUBLIC_IZIPAY_PUBLIC_KEY=TU_CLAVE_PUBLICA

# URL base del checkout Izipay:
#   Sandbox:    https://sandbox-checkout.izipay.pe
#   Producción: https://checkout.izipay.pe
NEXT_PUBLIC_IZIPAY_BASE_URL=https://sandbox-checkout.izipay.pe

# ── Email ────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=tickets@perionentertainment.com

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://festientrada.com
